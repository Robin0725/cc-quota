{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC Quota",
  "version": "0.5.5",
  "identifier": "app.ccquota.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "widget",
        "title": "CC Quota",
        "width": 100,
        "height": 100,
        "minWidth": 100,
        "minHeight": 100,
        "maxWidth": 320,
        "maxHeight": 430,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Codex and Claude quota in the macOS menu bar",
    "longDescription": "A local-first macOS menu bar utility for Codex and Claude usage limits, with an optional transparent floating widget.",
    "copyright": "Copyright 2026 Robin0725 (Robin); based on Quota Float contributors",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
